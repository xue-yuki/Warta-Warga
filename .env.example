# === LLM via OpenRouter (fleksibel, ganti model lewat env) ===
# Daftar & ambil key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model cepat-murah untuk klasifikasi maksud & volume tinggi japri
OPENROUTER_FAST_MODEL=openai/gpt-4o-mini
# Model lebih dalam untuk penalaran klaim (3-label) & strukturisasi Agent 1
OPENROUTER_DEEP_MODEL=anthropic/claude-3.5-sonnet

# Header opsional yang disarankan OpenRouter
OPENROUTER_APP_URL=https://github.com/wartawarga
OPENROUTER_APP_NAME=Warta Warga

# === OCR CAPTCHA gambar (LaporGub, bukan Cloudflare/Turnstile) ===
# auto: coba Gemini lalu OpenRouter bila keduanya diset. Pilihan lain: gemini / openrouter
CAPTCHA_SOLVER_PROVIDER=auto
# Gemini/OpenAI-compatible endpoint. Bisa pakai VISION_* umum atau CAPTCHA_GEMINI_* khusus.
VISION_API_KEY=
VISION_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
VISION_MODEL=gemini-flash-lite-latest
CAPTCHA_GEMINI_API_KEY=
CAPTCHA_GEMINI_MODEL=
# OpenRouter fallback untuk OCR gambar. Wajib set model vision-capable.
CAPTCHA_OPENROUTER_API_KEY=
CAPTCHA_OPENROUTER_MODEL=
CAPTCHA_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# === Image Generation (ChatGPT) ===
# Key untuk memanggil generator gambar (opsional, fallback ke OPENAI_API_KEY / OPENROUTER_API_KEY)
IMAGE_API_KEY=
# Base URL API (default: https://api.openai.com/v1)
IMAGE_BASE_URL=
# Model gambar yang digunakan (default: gpt-image-2)
IMAGE_MODEL=gpt-image-2

# === Embeddings (lokal, untuk vector store RAG) ===
# local      -> Xenova/all-MiniLM-L6-v2 (semantik, download model sekali ~25MB)
# hashing    -> fallback tanpa download/jaringan (bag-of-words hashing)
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=Xenova/all-MiniLM-L6-v2

# === Database lokal (SQLite). Nanti dapat dipindah ke Supabase/pgvector ===
DB_PATH=./data/warta.db

# === WhatsApp (Baileys) ===
# Folder penyimpanan kredensial sesi (hasil scan QR)
WA_AUTH_DIR=./auth_state
# JID bot diisi otomatis saat login; boleh override untuk deteksi mention manual
BOT_JID=

# Wilayah default bila grup belum /start (untuk demo)
DEFAULT_WILAYAH_TAG=nasional

LAPORGUB_EMAIL=telkomlksai@gmail.com
LAPORGUB_PASSWORD=JagaWarga1993

# === AduanKonten (aduankonten.id) ===
ADUANKONTEN_BASE_URL=https://aduankonten.id
ADUANKONTEN_SESSION_PATH=./.aduankonten_session.json
ADUANKONTEN_USER_DATA_DIR=./.aduankonten_profile
ADUANKONTEN_DEBUG_DIR=
# Kosongkan untuk user-agent default browser. Isi hanya jika perlu menyamakan environment.
ADUANKONTEN_USER_AGENT=
# Opsional: set `chrome` jika Patchright tidak menemukan browser bawaan.
ADUANKONTEN_BROWSER_CHANNEL=
ADUANKONTEN_CHECK_INTERVAL_HOURS=6

# === AduanKonten Cloudflare challenge handler (best-effort) ===
# Handler ini hanya membantu flow headless. Jika Cloudflare tetap re-challenge,
# gunakan `npm run warmup:aduankonten -- --debug --wait-ms=300000`
# atau ulangi submit dengan `--headed`.
CLOUDFLARE_CAPTCHA_SOLVER=true
# Pilihan provider: gemini / openrouter
CLOUDFLARE_CAPTCHA_PROVIDER=openrouter
CLOUDFLARE_GEMINI_API_KEY=
CLOUDFLARE_GEMINI_MODEL=gemini-flash-lite-latest
CLOUDFLARE_OPENROUTER_API_KEY=
CLOUDFLARE_OPENROUTER_MODEL=google/gemini-flash-1.5
CLOUDFLARE_CAPTCHA_MAX_RETRIES=3
CLOUDFLARE_CAPTCHA_TIMEOUT_MS=60000

# Agent 2 service follow-up scheduler: LaporGub + AduanKonten
AGENT2_LAYANAN_CHECKERS_ENABLED=true
